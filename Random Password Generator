import tkinter as tk
from tkinter import ttk, messagebox
import random
import string
import json
import os

class PasswordGeneratorApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Генератор случайных паролей")
        self.root.geometry("500x450")

        self.history_file = "password_history.json"
        self.password_history = []

        self.create_widgets()
        self.load_history()

    def create_widgets(self):
        # Фрейм для настроек
        settings_frame = ttk.LabelFrame(self.root, text="Настройки пароля")
        settings_frame.pack(padx=10, pady=10, fill="x")

        # Ползунок длины пароля
        ttk.Label(settings_frame, text="Длина пароля:").grid(row=0, column=0, padx=5, pady=5, sticky="w")
        self.length_slider = tk.Scale(settings_frame, from_=8, to=32, orient="horizontal", length=300)
        self.length_slider.set(12) # Значение по умолчанию
        self.length_slider.grid(row=0, column=1, padx=5, pady=5)

        # Выбор символов
        ttk.Label(settings_frame, text="Типы символов:").grid(row=1, column=0, padx=5, pady=5, sticky="w")
        self.include_digits = tk.BooleanVar()
        self.include_letters = tk.BooleanVar()
        self.include_symbols = tk.BooleanVar()

        ttk.Checkbutton(settings_frame, text="Цифры", variable=self.include_digits).grid(row=1, column=1, padx=5, pady=5, sticky="w")
        ttk.Checkbutton(settings_frame, text="Буквы", variable=self.include_letters).grid(row=2, column=1, padx=5, pady=5, sticky="w")
        ttk.Checkbutton(settings_frame, text="Спецсимволы", variable=self.include_symbols).grid(row=3, column=1, padx=5, pady=5, sticky="w")

        self.include_digits.set(True)
        self.include_letters.set(True)
        self.include_symbols.set(True)

        # Кнопка генерации
        self.generate_button = ttk.Button(settings_frame, text="Сгенерировать пароль", command=self.generate_password)
        self.generate_button.grid(row=4, column=0, columnspan=2, pady=10)

        # Результат генерации
        self.password_result_label = ttk.Label(settings_frame, text="Ваш пароль:")
        self.password_result_label.grid(row=5, column=0, padx=5, pady=5, sticky="w")
        self.password_entry = ttk.Entry(settings_frame, width=30, state="readonly")
        self.password_entry.grid(row=5, column=1, padx=5, pady=5)

        # Фрейм для истории
        history_frame = ttk.LabelFrame(self.root, text="История генераций")
        history_frame.pack(padx=10, pady=10, fill="both", expand=True)

        # Таблица истории
        self.tree = ttk.Treeview(history_frame, columns=("Password"), show="headings")
        self.tree.heading("Password", text="Сгенерированные пароли")
        self.tree.pack(fill="both", expand=True, padx=5, pady=5)

    def generate_password(self):
        length = self.length_slider.get()

        # Проверка корректности ввода
        if not (8 <= length <= 32):
            messagebox.showerror("Ошибка", "Длина пароля должна быть от 8 до 32 символов.")
            return

        characters = ""
        if self.include_digits.get():
            characters += string.digits
        if self.include_letters.get():
            characters += string.ascii_letters
        if self.include_symbols.get():
            characters += string.punctuation

        if not characters:
            messagebox.showerror("Ошибка", "Выберите хотя бы один тип символов.")
            return

        password = ''.join(random.choice(characters) for _ in range(length))
        self.password_entry.configure(state="normal")
        self.password_entry.delete(0, tk.END)
        self.password_entry.insert(0, password)
        self.password_entry.configure(state="readonly")

        self.add_to_history(password)
        self.save_history()

    def add_to_history(self, password):
        self.password_history.append(password)
        self.tree.insert("", tk.END, values=(password,))

    def load_history(self):
        if os.path.exists(self.history_file):
            with open(self.history_file, "r") as f:
                try:
                    self.password_history = json.load(f)
                    for pw in self.password_history:
                        self.tree.insert("", tk.END, values=(pw,))
                except json.JSONDecodeError:
                    messagebox.showwarning("Предупреждение", f"Ошибка при чтении файла истории '{self.history_file}'. История будет пуста.")
                    self.password_history = []

    def save_history(self):
        with open(self.history_file, "w") as f:
            json.dump(self.password_history, f)

if __name__ == "__main__":
    root = tk.Tk()
    app = PasswordGeneratorApp(root)
    root.mainloop()
